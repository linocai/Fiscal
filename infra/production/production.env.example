# Install as /etc/fiscal/fiscal.env with owner root:fiscal and mode 0640.
# Replace every CHANGE_ME value. Never commit the installed file.

FISCAL_ENVIRONMENT=production
FISCAL_LOG_LEVEL=INFO
FISCAL_SERVICE_NAME=fiscal-api

# The application role is DML-only. Percent-encode reserved URL characters.
FISCAL_DATABASE_URL=postgresql+asyncpg://fiscal_app:CHANGE_ME@127.0.0.1:5432/fiscal
# Used only by root deployment tooling while it runs Alembic as the peer fiscal_migrator.
FISCAL_MIGRATION_DATABASE_URL=postgresql+asyncpg://fiscal_migrator@/fiscal?host=/var/run/postgresql
FISCAL_UV_BIN=/opt/fiscal/tools/uv/bin/uv
FISCAL_UV_VERSION=0.11.16
FISCAL_PYPI_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
FISCAL_UV_HTTP_TIMEOUT_SECONDS=60

# Intentionally too short so production configuration fails closed until replaced.
FISCAL_TOKEN_PEPPER=CHANGE_ME
FISCAL_TOKEN_PEPPER_VERSION=1
FISCAL_TOKEN_PENDING_TTL_MINUTES=15
FISCAL_RATE_LIMIT_READ_PER_MINUTE=120
FISCAL_RATE_LIMIT_WRITE_PER_MINUTE=30
FISCAL_RATE_LIMIT_AI_PER_MINUTE=10
FISCAL_RATE_LIMIT_FAILED_AUTH_PER_MINUTE=10

FISCAL_AI_PROVIDER=disabled
# When enabling the provider, add its HTTPS base URL, model and API key here.
FISCAL_AI_PROVIDER_TIMEOUT_SECONDS=15
FISCAL_AI_PROVIDER_MAX_RESPONSE_BYTES=65536

FISCAL_PUBLIC_BASE_URL=https://fiscal.linotsai.top
FISCAL_BACKUP_DATABASE=fiscal
FISCAL_BACKUP_RETENTION_DAYS=14
FISCAL_BACKUP_MAX_AGE_HOURS=30
FISCAL_RESTORE_VERIFY_STALE_HOURS=192
FISCAL_DISK_STATUS_STALE_MINUTES=60
FISCAL_OPERATIONS_STATUS_DIRECTORY=/var/lib/fiscal/operations
FISCAL_RELEASE_METADATA_FILE=/opt/fiscal/current/RELEASE
FISCAL_DISK_PATH=/var/lib/postgresql
FISCAL_DISK_WARNING_PERCENT=75
FISCAL_DISK_FAILURE_PERCENT=85

# Acceptance requires a real receiver. The generic receiver must accept a JSON body
# containing service, state, host and timestamp. Leave empty until one is selected.
FISCAL_ALERT_WEBHOOK_URL=
