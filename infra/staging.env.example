# Copy to infra/staging.env and replace every CHANGE_ME value.
# Never commit infra/staging.env.

FISCAL_DOMAIN=fiscal-staging.example.com
ACME_EMAIL=CHANGE_ME@example.com
FISCAL_IMAGE_TAG=staging

POSTGRES_DB=fiscal
POSTGRES_USER=fiscal
POSTGRES_PASSWORD=CHANGE_ME_USE_A_LONG_RANDOM_PASSWORD

# P1 uses one device-level bearer token. It is access protection, not a user identity.
FISCAL_DEVICE_TOKEN=CHANGE_ME_USE_A_LONG_RANDOM_TOKEN
